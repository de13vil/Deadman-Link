# Backend Environment Configuration
# Copy this file to .env and fill in your production values

# Express Server Port
PORT=5050

# URL of your deployed React frontend (e.g., https://mydeadmanlink.com)
FRONTEND_URL=http://localhost:5173

# MongoDB Connection String (Use MongoDB Atlas for production)
MONGO_URI=mongodb://127.0.0.1:27017/deadman_link

# Security Key to allow creating new Admin accounts via /admin/register
ADMIN_SECURITY_KEY=YourSuperSecretAdminKeyHere

# JWT Secret for signing admin authentication tokens (Make this long and secure)
JWT_SECRET=YourSuperSecretJWTKeyHere

# Google Gemini API Key for AI Analytics
GEMINI_API_KEY=AIzaSy...
